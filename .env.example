# Coinbase credentials (required for live/paper and data fetches)
COINBASE_API_KEY=your_coinbase_api_key
COINBASE_API_SECRET=your_coinbase_api_secret
COINBASE_API_PASSPHRASE=your_coinbase_api_passphrase_optional

# Optional sandbox toggle
COINBASE_USE_SANDBOX=false

# FRED API key (required when fred.enabled=true)
FRED_API_KEY=your_key_here
